# ==========================================
# Root .gitignore for Enterprise Monorepo
# ==========================================

# Secrets & Environment variables
.env
*.env
!.env.example

# IDE & OS Artifacts
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Java & Maven (Backend)
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
*.log
hs_err_pid*

# Node.js & Vite (Frontend & Root)
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
