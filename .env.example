# ==========================================
# University ERP - Environment Template (.env.example)
# Copy this file to .env before running docker-compose up -d
# ==========================================

# Database configuration
POSTGRES_DB=university_erp_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here

# 512-bit (64 bytes) secure Base64 JWT Secret Key
# Generate one using: openssl rand -base64 64
JWT_SECRET=YourSuperSecretKeyGoesHereAtLeast64BytesLongForHS512Algorithm===========
